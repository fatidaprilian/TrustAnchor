NODE_ENV=production
WEB_PORT=3000
APP_URL=https://trustanchor.example.edu
POSTGRES_DB=trustanchor
POSTGRES_USER=trustanchor
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DATABASE_URL=postgresql://trustanchor:replace-with-strong-postgres-password@postgres:5432/trustanchor
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET_NAME=trustanchor-documents
SESSION_SECRET=replace-with-at-least-32-random-characters
DOCUMENT_MASTER_KEY=replace-with-base64-encoded-32-byte-key
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-sha256-hex-password-hash
SIGNATURE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nreplace-with-rsa-private-key\n-----END PRIVATE KEY-----"
SIGNATURE_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\nreplace-with-rsa-public-key\n-----END PUBLIC KEY-----"
DEFAULT_INSTITUTION_ID=inst_demo
