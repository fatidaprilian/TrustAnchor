NODE_ENV=development
APP_URL=http://localhost:3000
POSTGRES_DB=trustanchor
POSTGRES_USER=trustanchor
POSTGRES_PASSWORD=your-postgres-password-here
DATABASE_URL=postgresql://trustanchor:your-password-here@postgres:5432/trustanchor
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET_NAME=trustanchor-documents
SESSION_SECRET=your-session-secret-here
DOCUMENT_MASTER_KEY=your-base64-32-byte-master-key-here
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=your-bootstrap-admin-password-here
SIGNATURE_PRIVATE_KEY_PEM=your-private-key-pem-here
SIGNATURE_PUBLIC_KEY_PEM=your-public-key-pem-here
DEFAULT_INSTITUTION_ID=inst_demo
